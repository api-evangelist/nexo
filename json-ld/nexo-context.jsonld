    "url": "schema:url",
    "logo": "schema:logo",
    "sameAs": "schema:sameAs",
    "provider": "schema:provider",
    "offers": "schema:offers",
    "WebAPI": "schema:WebAPI",
    "documentation": "schema:documentation",
    "termsOfService": "schema:termsOfService",
    "apiEndpoint": "pro:apiEndpoint",
    "authMethod": "aid:authMethod",
    "rateLimit": "aid:rateLimit",
    "webhook": "aid:webhook",
    "depositAddress": "pg:depositAddress",
    "referenceId": "pg:referenceId",
